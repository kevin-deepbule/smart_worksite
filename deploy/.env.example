TZ=Asia/Shanghai

# =========================
# MySQL
# =========================
MYSQL_VERSION=8.4
MYSQL_PORT=13306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=smart_worksite
MYSQL_USER=worksite
MYSQL_PASSWORD=worksite

# Java连接MySQL
DB_HOST=localhost
DB_USERNAME=worksite
DB_PASSWORD=worksite

# =========================
# Redis
# =========================
REDIS_VERSION=7.2-alpine
REDIS_PORT=16379
REDIS_HOST=localhost

# =========================
# MinIO
# =========================
MINIO_VERSION=RELEASE.2025-04-22T22-12-26Z
MINIO_MC_VERSION=RELEASE.2025-04-16T18-13-26Z

MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

MINIO_BUCKET=smart-worksite

FILE_ACCESS_URL_EXPIRE_SECONDS=600
FILE_MAX_SIZE_BYTES=104857600
FILE_MULTIPART_MAX_FILE_SIZE=100MB
FILE_MULTIPART_MAX_REQUEST_SIZE=100MB
FILE_PARSE_ENABLED=true
FILE_PARSE_MAX_PAGES=100
FILE_PARSE_RESULT_PREVIEW_LENGTH=2000
FILE_PARSE_MAX_INPUT_CHARS=120000
QWEN_VL_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_VL_API_KEY=
QWEN_VL_MODEL=qwen-vl-plus
QWEN_VL_CONNECT_TIMEOUT_MS=5000
QWEN_VL_READ_TIMEOUT_MS=120000
# Java MinIO Client
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# =========================
# CryptoAgentV3
# =========================
CRYPTO_AGENT_V3_BASE_URL=http://127.0.0.1:8012
CRYPTO_AGENT_V3_INVOKE_PATH=/v1/report-generation/invoke
CRYPTO_AGENT_V3_CONNECT_TIMEOUT_SECONDS=5
CRYPTO_AGENT_V3_READ_TIMEOUT_SECONDS=3000000

# =========================
# Java
# =========================
SERVER_PORT=8080
